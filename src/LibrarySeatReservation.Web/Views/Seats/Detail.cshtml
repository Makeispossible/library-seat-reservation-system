@model Seat
@{
    ViewData["Title"] = $"座位 {Model.SeatNumber}";
}

<div class="row">
    <div class="col-lg-8">
        <!-- 座位信息 -->
        <div class="card-custom-static mb-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="mb-1">@Model.SeatNumber</h4>
                    <p class="text-secondary mb-2" style="font-size:14px;">
                        @Model.Area · @Model.Floor
                    </p>
                    <div>
                        @{
                            var badgeClass = ViewBag.DisplayStatus switch
                            {
                                "空闲" => "badge-available",
                                "已预约" => "badge-reserved",
                                "使用中" => "badge-inuse",
                                "维护中" => "badge-maintenance",
                                _ => "badge-secondary"
                            };
                        }
                        <span class="badge-status badge-lg @badgeClass">@ViewBag.DisplayStatus</span>
                    </div>
                </div>
                <div>
                    @if (ViewBag.DisplayStatus == "空闲")
                    {
                        <a class="btn btn-custom-primary" asp-controller="Reservation" asp-action="Create" asp-route-id="@Model.Id">
                            预约此座位
                        </a>
                    }
                    else
                    {
                        <span class="text-secondary" style="font-size:13px;">当前不可预约</span>
                    }
                </div>
            </div>
        </div>

        <!-- 今日预约时段 -->
        <div class="card-custom-static">
            <h5 class="section-title-sm mb-3">今日预约时段</h5>
            @if (ViewBag.TodayReservations == null || ViewBag.TodayReservations.Count == 0)
            {
                <div class="empty-state" style="padding:30px 20px;">
                    <p>今日暂无预约记录</p>
                </div>
            }
            else if (ViewBag.TodayReservations is List<dynamic> reservations)
            {
                foreach (var r in reservations)
                {
                    <div class="time-slot-item">
                        <div>
                            <strong>@r.StartTime.ToString(@"hh\:mm") - @r.EndTime.ToString(@"hh\:mm")</strong>
                            <div class="text-secondary" style="font-size:12px;">@r.UserName</div>
                        </div>
                        @{
                            var rBadgeClass = r.DisplayStatus switch
                            {
                                "待开始" => "badge-pending",
                                "使用中" => "badge-inuse",
                                "已完成" => "badge-completed",
                                "已取消" => "badge-cancelled",
                                _ => "badge-secondary"
                            };
                        }
                        <span class="badge-status @rBadgeClass">@r.DisplayStatus</span>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-custom-outline" asp-controller="Seats" asp-action="Index">← 返回座位列表</a>
</div>
