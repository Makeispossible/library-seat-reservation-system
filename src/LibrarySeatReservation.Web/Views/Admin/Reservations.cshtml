@{
    ViewData["Title"] = "预约管理";
    Layout = "_AdminLayout";
}

<h4 class="section-title mb-4">预约管理</h4>

@{
    var reservations = ViewBag.Reservations as List<dynamic>;
}

@if (reservations == null || reservations.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h6>暂无预约记录</h6>
        <p>目前还没有任何预约记录。</p>
    </div>
}
else
{
    <div class="table-responsive-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>座位</th>
                    <th>区域</th>
                    <th>用户</th>
                    <th>日期</th>
                    <th>时间</th>
                    <th>状态</th>
                    <th>创建时间</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in reservations)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td><strong>@r.SeatNumber</strong></td>
                        <td>@r.Area</td>
                        <td>@r.UserName</td>
                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                        <td>@r.StartTime.ToString(@"hh\:mm") - @r.EndTime.ToString(@"hh\:mm")</td>
                        <td>
                            @{
                                var badgeClass = r.DisplayStatus switch
                                {
                                    "待开始" => "badge-pending",
                                    "使用中" => "badge-inuse",
                                    "已完成" => "badge-completed",
                                    "已取消" => "badge-cancelled",
                                    _ => "badge-secondary"
                                };
                            }
                            <span class="badge-status @badgeClass">@r.DisplayStatus</span>
                        </td>
                        <td style="font-size:13px;">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
