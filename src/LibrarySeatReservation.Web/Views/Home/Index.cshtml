@{
    ViewData["Title"] = "首页";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        @if (ViewBag.IsLoggedIn)
        {
            <!-- 已登录欢迎 -->
            <div class="text-center mb-4">
                <h1 class="display-6 fw-bold" style="color:var(--color-primary);">图书馆座位预约</h1>
                <p class="text-secondary">欢迎回来，开始预约座位吧</p>
            </div>

            <div class="card-custom-static mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">你好，<strong>@ViewBag.CurrentUser</strong> 👋</h5>
                        <p class="text-secondary mb-0" style="font-size:14px;">可前往座位列表预约座位</p>
                    </div>
                    <div>
                        <a class="btn btn-custom-primary" asp-controller="Seats" asp-action="Index">查看座位</a>
                    </div>
                </div>
            </div>

            <div class="row mt-4 g-3">
                <div class="col-md-6">
                    <div class="card-custom-static text-center">
                        <div style="font-size:32px;margin-bottom:8px;">🪑</div>
                        <h6>浏览座位</h6>
                        <p class="text-secondary" style="font-size:13px;">查看各区域座位空闲情况</p>
                        <a class="btn btn-custom-primary btn-custom-sm" asp-controller="Seats" asp-action="Index">去看看</a>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-custom-static text-center">
                        <div style="font-size:32px;margin-bottom:8px;">📋</div>
                        <h6>我的预约</h6>
                        <p class="text-secondary" style="font-size:13px;">查看和取消我的预约记录</p>
                        <a class="btn btn-custom-primary btn-custom-sm" asp-controller="Reservation" asp-action="My">去看看</a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- 未登录欢迎 -->
            <div class="text-center mb-4">
                <h1 class="display-6 fw-bold" style="color:var(--color-primary);">图书馆座位预约</h1>
                <p class="text-secondary">登录后即可预约图书馆座位</p>
            </div>

            <div class="card-custom-static text-center mb-4">
                <div style="font-size:48px;margin-bottom:12px;">🏛️</div>
                <h5 class="mb-3">欢迎使用图书馆座位预约系统</h5>
                <p class="text-secondary" style="font-size:14px;max-width:360px;margin:0 auto 20px;">
                    请登录或注册账号后浏览座位、预约座位。
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a class="btn btn-custom-primary" asp-controller="Account" asp-action="Login">登录</a>
                    <a class="btn btn-custom-outline" asp-controller="Account" asp-action="Register">注册</a>
                </div>
            </div>
        }
    </div>
</div>
