@{
    ViewData["Title"] = "我的预约";
}

<h4 class="section-title mb-4">我的预约</h4>

@{
    var reservations = ViewBag.Reservations as List<dynamic>;
}

@if (reservations == null || reservations.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h6>暂无预约记录</h6>
        <p>你还没有预约过座位，去预约一个吧。</p>
        <a class="btn btn-custom-primary" asp-controller="Seats" asp-action="Index">去预约</a>
    </div>
}
else
{
    <!-- 桌面端表格 -->
    <div class="table-responsive-custom hide-mobile">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>座位</th>
                    <th>区域</th>
                    <th>日期</th>
                    <th>时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in reservations)
                {
                    <tr>
                        <td><strong>@r.SeatNumber</strong></td>
                        <td>@r.Area</td>
                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                        <td>@r.StartTime.ToString(@"hh\:mm") - @r.EndTime.ToString(@"hh\:mm")</td>
                        <td>
                            @{
                                var badgeClass = r.DisplayStatus switch
                                {
                                    "待开始" => "badge-pending",
                                    "使用中" => "badge-inuse",
                                    "已完成" => "badge-completed",
                                    "已取消" => "badge-cancelled",
                                    _ => "badge-secondary"
                                };
                            }
                            <span class="badge-status @badgeClass">@r.DisplayStatus</span>
                        </td>
                        <td>
                            @if (r.CanCancel)
                            {
                                <form method="post" asp-controller="Reservation" asp-action="Cancel" asp-route-id="@r.Id"
                                      onsubmit="return confirm('确定取消此预约？')">
                                    <button type="submit" class="btn btn-custom-danger btn-custom-sm">取消</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-secondary" style="font-size:13px;">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 移动端卡片 -->
    <div class="d-md-none">
        <div class="row g-3">
            @foreach (var r in reservations)
            {
                <div class="col-12">
                    <div class="reservation-card">
                        <div class="rc-top">
                            <div>
                                <div class="rc-seat">@r.SeatNumber</div>
                                <div class="rc-meta">@r.Area</div>
                            </div>
                            @{
                                var bClass = r.DisplayStatus switch
                                {
                                    "待开始" => "badge-pending",
                                    "使用中" => "badge-inuse",
                                    "已完成" => "badge-completed",
                                    "已取消" => "badge-cancelled",
                                    _ => "badge-secondary"
                                };
                            }
                            <span class="badge-status @bClass">@r.DisplayStatus</span>
                        </div>
                        <div class="rc-time">
                            @r.Date.ToString("yyyy-MM-dd") &middot; @r.StartTime.ToString(@"hh\:mm") - @r.EndTime.ToString(@"hh\:mm")
                        </div>
                        @if (r.CanCancel)
                        {
                            <div class="mt-2">
                                <form method="post" asp-controller="Reservation" asp-action="Cancel" asp-route-id="@r.Id"
                                      onsubmit="return confirm('确定取消此预约？')">
                                    <button type="submit" class="btn btn-custom-danger btn-custom-sm">取消预约</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
