<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 图书馆座位预约</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySeatReservation.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- 用户端蓝色导航栏 -->
    <nav class="navbar navbar-expand-sm navbar-dark navbar-user">
        <div class="container-fluid page-container" style="max-width:1200px;padding-top:0;padding-bottom:0;">
            <a class="navbar-brand" href="/">📚 座位预约</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#userNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="userNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Seats" asp-action="Index">座位列表</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Reservation" asp-action="My">我的预约</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Login">管理后台</a>
                    </li>
                </ul>
                <!-- 体验账号切换 -->
                <div class="d-flex align-items-center gap-2">
                    <span class="user-display">当前：<strong>@(ViewBag.CurrentUser ?? "未选择")</strong></span>
                    <form asp-controller="Home" asp-action="SwitchUser" method="post" class="d-inline">
                        <select name="userId" class="user-selector" onchange="this.form.submit()">
                            <option value="">切换账号</option>
                            @if (ViewBag.StudentUsers != null)
                            {
                                foreach (var u in ViewBag.StudentUsers)
                                {
                                    <option value="@u.Id">@u.Name</option>
                                }
                            }
                        </select>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- TempData 消息 -->
    <div class="page-container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-custom-success mb-3">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-custom-error mb-3">@TempData["ErrorMessage"]</div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-simple">
        <span>图书馆座位预约系统 &copy; @DateTime.Now.Year — 课程设计项目</span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
