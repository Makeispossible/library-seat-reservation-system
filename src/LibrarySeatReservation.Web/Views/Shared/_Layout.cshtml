@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 图书馆座位预约</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySeatReservation.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- 用户端蓝色导航栏 -->
    <nav class="navbar navbar-expand-sm navbar-dark navbar-user">
        <div class="container-fluid page-container" style="max-width:1200px;padding-top:0;padding-bottom:0;">
            <a class="navbar-brand" href="/">📚 座位预约</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#userNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="userNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? " active" : "")" asp-area="" asp-controller="Home" asp-action="Index">首页</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link@(ViewContext.RouteData.Values["controller"]?.ToString() == "Seats" ? " active" : "")" asp-area="" asp-controller="Seats" asp-action="Index">座位列表</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservation" ? " active" : "")" asp-area="" asp-controller="Reservation" asp-action="My">我的预约</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link@(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? " active" : "")" asp-area="" asp-controller="Admin" asp-action="Login">管理后台</a>
                    </li>
                </ul>
                <!-- 用户登录状态 -->
                <div class="d-flex align-items-center gap-2">
                    @{
                        var loggedInUserId = Context.Session.GetInt32("UserId");
                        var loggedInUserName = Context.Session.GetString("UserName");
                    }
                    @if (loggedInUserId.HasValue)
                    {
                        <span class="user-display">你好，<strong>@loggedInUserName</strong></span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-custom-navbar">退出</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-custom-primary btn-custom-sm"
                           style="padding:4px 12px;font-size:13px;">登录</a>
                        <a asp-controller="Account" asp-action="Register"
                           class="btn btn-custom-primary btn-custom-sm"
                           style="padding:4px 12px;font-size:13px;">注册</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Toast 通知容器（由 site.js 控制） -->
    <div id="toastContainer" class="toast-container-custom" aria-live="polite" aria-atomic="true"></div>

    <!-- TempData 消息 -->
    <div class="page-container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-custom-success mb-3 alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-custom-error mb-3 alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-simple">
        <span>图书馆座位预约系统 &copy; @DateTime.Now.Year — 课程设计项目</span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
