@model ErrorViewModel
@{
    ViewData["Title"] = "出错了";
}

<div class="page-container" style="text-align:center;padding-top:80px;">
    <div style="font-size:72px;margin-bottom:16px;opacity:0.6;">⚠️</div>
    <h1 class="section-title" style="font-size:28px;">500 — 服务器内部错误</h1>
    <p style="color:var(--color-text-secondary);margin-bottom:8px;font-size:var(--font-size-base);">
        处理您的请求时发生了错误，请稍后重试。
    </p>
    @if (Model.ShowRequestId)
    {
        <p style="font-size:var(--font-size-xs);color:var(--color-text-secondary);margin-bottom:24px;">
            请求 ID：<code>@Model.RequestId</code>
        </p>
    }
    else
    {
        <p style="margin-bottom:24px;"></p>
    }
    <a href="/" class="btn btn-custom-primary">返回首页</a>
    <a href="javascript:history.back()" class="btn btn-custom-outline" style="margin-left:8px;">返回上一步</a>
</div>
