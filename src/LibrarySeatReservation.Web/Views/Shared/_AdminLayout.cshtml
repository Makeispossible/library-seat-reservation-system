<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 管理后台</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibrarySeatReservation.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- 管理端深色导航栏 -->
    <nav class="navbar navbar-expand-sm navbar-dark navbar-admin">
        <div class="container-fluid page-container" style="max-width:1400px;padding-top:0;padding-bottom:0;">
            <a class="navbar-brand" href="/Admin/Reservations">📚 管理后台</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Reservations">预约管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Seats">座位管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Stats">统计</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Seats" asp-action="Index">返回前台</a>
                    </li>
                </ul>
                <!-- 管理员退出 -->
                <div class="d-flex align-items-center gap-2">
                    <span class="user-display">管理员：<strong>@(Context.Session.GetString("AdminName") ?? "管理员")</strong></span>
                    <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-custom-danger btn-custom-sm">退出</button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- TempData 消息 -->
    <div class="admin-container-wide page-container" style="max-width:1400px;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-custom-success mb-3">@TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-custom-error mb-3">@TempData["ErrorMessage"]</div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-simple">
        <span>图书馆座位预约系统 &copy; @DateTime.Now.Year — 管理后台</span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
